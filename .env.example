# APEX LLM Router - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google AI
GOOGLE_API_KEY=your_google_key_here

# BytePlus
BYTEPLUS_API_KEY=your_byteplus_key_here
BYTEPLUS_BASE_URL=https://ark.byteplusapi.com/v1

# SambaNova
SAMBANOVA_API_KEY=your_sambanova_key_here
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1

# NVIDIA
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Mistral
MISTRAL_API_KEY=your_mistral_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Ollama (Local)
OLLAMA_HOST=http://localhost:11434

# Note: Remove the "your_" prefix and "_here" suffix, replace with actual keys
