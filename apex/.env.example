# ============================================================
# APEX LLM Router - Environment Variables
# Copy this file to .env and fill in your actual API keys
# ============================================================

# --- OpenRouter (DeepSeek R1, Qwen3, fallbacks) ---
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Groq (ultra-fast LLaMA 3.3 70B — ENGR. MARCUS) ---
# Get key: https://console.groq.com/keys
# Multiple keys for rate limit rotation - add additional keys if needed
GROQ_API_KEY=your_groq_key_here
GROQ_API_KEY_2=your_groq_key_2_here
GROQ_API_KEY_3=your_groq_key_3_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Google AI (Gemini 2.5 Pro/Flash — DR. YUKI, ENGR. FATIMA) ---
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- BytePlus ModelArk (NLP sentiment — DR. JABARI, 5M free tokens/day) ---
# Get key: https://console.byteplus.com/ark/region:ark+ap-southeast-1/apikey
# IMPORTANT: The model value must be your Endpoint ID from the ModelArk console
# (not a model name). Go to: console.byteplus.com → ModelArk → Inference Endpoints
# → create endpoint → copy the Endpoint ID (looks like: ep-20240101-xxxxxx)
BYTEPLUS_API_KEY=your_byteplus_key_here
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
BYTEPLUS_ENDPOINT_ID=ep-your-endpoint-id-here

# --- SambaNova (Qwen2.5 72B — DR. SIPHO) ---
# Get key: https://cloud.sambanova.ai/apis
SAMBANOVA_API_KEY=your_sambanova_key_here
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1

# --- NVIDIA NIM (Nemotron — ENGR. CHIOMA creative tasks) ---
# Get key: https://build.nvidia.com (sign in → get API key)
# Correct model ID for NVIDIA NIM API:
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# --- Mistral (Codestral — DR. SARA testing) ---
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# --- DeepSeek (direct API backup for DR. AMARA math reasoning) ---
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Azure OpenAI (DR. PRIYA on-chain + PROF. KWAME architecture) ---
# Get from: portal.azure.com → Azure OpenAI → your resource → Keys and Endpoint
# IMPORTANT: You must deploy models first in Azure Portal:
#   portal.azure.com → Azure OpenAI → your resource
#   → Model deployments → Deploy model → choose gpt-4o
# The deployment NAME you choose must match the values below exactly.
# Example: if you named your deployment "my-gpt4o" then use "my-gpt4o" below.
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://pp-rg.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_gpt4o=gpt-4o
AZURE_OPENAI_DEPLOYMENT_gpt-4o-mini=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# --- Azure Infrastructure (Cosmos DB, App Insights) ---
AZURE_COSMOS_CONNECTION_STRING=your_azure_cosmos_connection_string_here

# --- Ollama (local fallback — no key needed) ---
# Make sure Ollama is running: ollama serve
# Required models: ollama pull llama3.1 / deepseek-coder / qwen2.5-coder / phi4
OLLAMA_HOST=http://localhost:11434

# --- Alibaba Cloud (DISABLED — enable billing first) ---
# ALIBABA_API_KEY=your_key_here
# ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ============================================================
# APEX SYSTEM SETTINGS
# ============================================================
APEX_PAPER_MODE=true
APEX_SYMBOLS=XBTUSD,ETHUSD,SOLUSD
APEX_CYCLE_INTERVAL=60
APEX_LOG_LEVEL=INFO

# --- Kraken ---
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here
KRAKEN_CLI_PATH=kraken

# --- PRISM / Strykr ---
PRISM_API_KEY=LABLAB
PRISM_API_URL=https://api.prism.strykr.ai

# --- Lablab.ai Hackathon Shared Contracts (Ethereum Sepolia) ---
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111
AGENT_REGISTRY_ADDRESS=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
HACKATHON_VAULT_ADDRESS=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90
RISK_ROUTER_ADDRESS=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
REPUTATION_REGISTRY_ADDRESS=0x423a9904e39537a9997fbaF0f220d79D7d545763
VALIDATION_REGISTRY_ADDRESS=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1
APEX_AGENT_ID='26'
APEX_OPERATOR_PRIVATE_KEY=your_operator_private_key_here
APEX_AGENT_WALLET_PRIVATE_KEY=your_agent_wallet_private_key_here

# --- On-chain (ERC-8004, Base Sepolia Testnet) ---
BASE_RPC_URL=https://sepolia.base.org
APEX_PRIVATE_KEY=your_apex_private_key_here
IDENTITY_REGISTRY_ADDRESS=0xa491D7Ce1552f332543FF249DBb3ccbAA046b3C1
REPUTATION_REGISTRY_ADDRESS=0xCdB1dca01BFDB3CB62354DfAdcDC638187bC0171
VALIDATION_REGISTRY_ADDRESS=0xd9be9de6eD8DD4AB9a1c1C55F54FECa35Dd1Dde6
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here
